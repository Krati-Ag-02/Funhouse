rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own scores subcollection.
    // Nobody can read another user's scores, and nobody can write
    // scores while signed out — this is the actual security boundary
    // for the app, since there's no server in front of Firestore.
    match /users/{userId}/scores/{gameId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
